{
  "extends": ["config:recommended", ":disableDependencyDashboard"],
  "includePaths": ["package.json"],
  "enabledManagers": ["npm"],
  "branchPrefix": "renovate/",
  "automergeType": "pr",
  "automerge": true,
  "platformAutomerge": true,
  "packageRules": [
    {
      "description": "Update ZIO Ecosystem Docs skills",
      "matchPackageNames": ["^@zio\\.dev\\/.*"],
      "ignoreUnstable": false,
      "enabled": true,
      "labels": ["dependencies", "skills-sync"],
      "automergeType": "pr",
      "automerge": true
    }
  ]
}
